@model EditArticleViewModel

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">

        <div class="d-flex align-items-center mb-4 gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">← Înapoi</a>
            <h1 class="h3 mb-0">Editează articolul</h1>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark fw-semibold">
                Modificare articol
            </div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" placeholder="Titlul articolului" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-semibold"></label>
                        <textarea asp-for="Content" class="form-control" rows="8" placeholder="Conținutul articolului..."></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label fw-semibold"></label>
                        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                            <option value="">-- Selectați categoria --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Imagine articol</label>
                        @if (Model.ExistingImagePath != null)
                        {
                            <div class="mb-2">
                                <img src="@Model.ExistingImagePath"
                                     alt="Imagine curentă"
                                     class="img-thumbnail d-block"
                                     style="max-height: 200px; object-fit: cover;" />
                                <p class="text-muted small mt-1">Imagine curentă — încarcă una nouă pentru a o înlocui</p>
                            </div>
                        }
                        <input type="file" name="Upload" class="form-control" accept="image/*" />
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-warning fw-semibold px-4">Salvează modificările</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Anulează</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

